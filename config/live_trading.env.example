# Copy to config/live_trading.env on the deployment host.
# Leave every live gate set to "no" until the operator is ready to enable it.

WANG_ALLOW_LIVE_TRADING=no
WANG_ALLOW_LIVE_CRYPTO=no
WANG_ALLOW_LIVE_FUTURES=no

# Optional secrets backend.
WANG_SECRETS_BACKEND=env
WANG_MASTER_KEY=
WANG_AUDIT_HMAC_KEY=

# Broker/API credentials may also live in config/live_trading.yaml.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
DB_PASSWORD=password
